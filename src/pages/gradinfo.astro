---
// src/pages/gradinfo.astro
// Hidden page — not linked in navigation
import immaculataImg from '../assets/Immaculata-PencilSketch.png';
import parkingMap from '../assets/usd2026-grad-parking.png';
const title = "Jun Clemente — M.S. Graduation · May 22, 2026";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --navy: #1a2e4a;
      --gold: #C8A84B;
      --light-gold: #e8d48b;
      --text: #2c2c2c;
      --muted: #6b7280;
      --bg: #fafaf8;
      --card-bg: #ffffff;
      --border: #e5e0d5;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Montserrat', sans-serif;
      background-color: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 2rem 1rem 4rem;
    }

    .container {
      max-width: 600px;
      margin: 0 auto;
    }

    /* Header */
    header {
      text-align: center;
      padding: 2.5rem 0 2rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2rem;
    }

    .eyebrow {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 6vw, 2.75rem);
      font-weight: 600;
      color: var(--navy);
      line-height: 1.15;
      margin-bottom: 0.5rem;
    }

    .degree {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-style: italic;
      color: var(--muted);
    }

    .intro {
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 1rem;
      letter-spacing: 0.02em;
    }

    /* Sections */
    .section {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1.25rem;
    }

    .section-label {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 0.25rem;
    }

    .section-meta {
      font-size: 0.8rem;
      font-weight: 300;
      color: var(--muted);
      margin-bottom: 1.25rem;
      line-height: 1.6;
    }

    /* Links */
    .link-list {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .link-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
      padding: 0.65rem 0.9rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--bg);
      transition: border-color 0.2s, background 0.2s;
    }

    .link-item:hover {
      border-color: var(--gold);
      background: #fffdf5;
    }

    .link-icon {
      font-size: 1rem;
      flex-shrink: 0;
    }

    .link-content {
      display: flex;
      flex-direction: column;
    }

    .link-label {
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--navy);
      line-height: 1.3;
    }

    .link-sub {
      font-size: 0.7rem;
      font-weight: 300;
      color: var(--muted);
    }

    /* RSVP note */
    .rsvp-note {
      margin-top: 1rem;
      padding: 0.75rem 0.9rem;
      background: #fffbf0;
      border: 1px solid var(--light-gold);
      border-radius: 6px;
      font-size: 0.78rem;
      color: var(--text);
      font-style: italic;
    }

    /* Parking note */
    .parking-note {
      margin-top: 1rem;
      font-size: 0.75rem;
      color: var(--muted);
      font-style: italic;
      line-height: 1.6;
    }

    /* Parking map */
    .parking-map {
      margin-top: 1rem;
      width: 100%;
      border-radius: 6px;
      border: 1px solid var(--border);
    }

    .parking-map-caption {
      font-size: 0.7rem;
      color: var(--muted);
      text-align: center;
      margin-top: 0.4rem;
      font-style: italic;
    }

    /* Divider */
    .divider {
      height: 1px;
      background: var(--border);
      margin: 1rem 0;
    }

    /* Footer */
    footer {
      text-align: center;
      margin-top: 2.5rem;
      font-size: 0.72rem;
      color: var(--muted);
      font-weight: 300;
    }

    .bg-image {
  position: fixed;
  inset: 0;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  opacity: 0.15;
  z-index: 0;
}

.container {
  position: relative;
  z-index: 1;
}
  </style>
</head>
<body>
<div class="bg-image" style={`background-image: url(${immaculataImg.src})`}></div>
  <div class="container">
    <header>
      <p class="eyebrow">You're Invited</p>
      <h1>Jun Clemente</h1>
      <p class="degree">Master of Science, Applied Data Science</p>
      <p class="intro">Here are helpful links for the celebration</p>
    </header>

    <!-- Ceremony Section -->
    <div class="section">
      <p class="section-label">Ceremony</p>
      <p class="section-title">Graduate II Ceremony</p>
      <p class="section-meta">
        May 22, 2026 · 2:30 p.m.<br />
        Jenny Craig Pavilion · University of San Diego
      </p>

      <div class="link-list">
        <a class="link-item" href="https://maps.app.goo.gl/V9x77CrXhoVxWjcr7" target="_blank" rel="noopener">
          <span class="link-icon">📍</span>
          <span class="link-content">
            <span class="link-label">Jenny Craig Pavilion</span>
            <span class="link-sub">Open in Google Maps</span>
          </span>
        </a>

        <a class="link-item" href="https://commencement.sandiego.edu/" target="_blank" rel="noopener">
          <span class="link-icon">🎓</span>
          <span class="link-content">
            <span class="link-label">Livestream & Digital Program</span>
            <span class="link-sub">commencement.sandiego.edu</span>
          </span>
        </a>

        <a class="link-item" href="https://www.sandiego.edu/commencement/" target="_blank" rel="noopener">
          <span class="link-icon">📋</span>
          <span class="link-content">
            <span class="link-label">Commencement Information & Schedule</span>
            <span class="link-sub">sandiego.edu/commencement</span>
          </span>
        </a>

        <a class="link-item" href="https://www.sandiego.edu/commencement/faqs.php" target="_blank" rel="noopener">
          <span class="link-icon">❓</span>
          <span class="link-content">
            <span class="link-label">2026 Commencement FAQs</span>
            <span class="link-sub">sandiego.edu/commencement/faqs.php</span>
          </span>
        </a>
      </div>

      <div class="parking-note">
        <p>🅿️ <strong>Parking is complimentary</strong> on campus May 21–24. Use the <strong>Main Parking Structure (MS)</strong> or <strong>West Parking Structure (WS)</strong>. Follow signs and traffic personnel on arrival.</p>
        <p style="margin-top: 0.5rem;">After parking, proceed to the <strong>Guest Entrance at Eagen Plaza</strong> for the security checkpoint. The arena opens <strong>90 minutes before</strong> the ceremony.</p>
        <p style="margin-top: 0.5rem;">🚗 Rideshare drop-off/pick-up is at the <strong>Vistas Lot</strong> (west of Main Entrance on Linda Vista Rd). USD buses and ADA shuttles will be available.</p>
      </div>

      <img src={parkingMap.src} alt="USD 2026 Commencement Parking Map" class="parking-map" />
      <p class="parking-map-caption">USD 2026 Commencement — Parking &amp; Transportation Map</p>

      <div class="link-list" style="margin-top: 0.75rem;">
        <a class="link-item" href="https://www.sandiego.edu/commencement/guest.php" target="_blank" rel="noopener">
          <span class="link-icon">👥</span>
          <span class="link-content">
            <span class="link-label">Full Guest Information</span>
            <span class="link-sub">Parking, accessibility, hotels & more</span>
          </span>
        </a>
      </div>
    </div>

    <!-- Dinner Section -->
    <div class="section">
      <p class="section-label">Dinner</p>
      <p class="section-title">Natsumi Buffet</p>
      <p class="section-meta">
        7040 Miramar Rd., San Diego, CA 92121<br />
        858.695.0888
      </p>

      <div class="link-list">
        <a class="link-item" href="https://maps.app.goo.gl/RDRGjWvc2F3xCrYh7" target="_blank" rel="noopener">
          <span class="link-icon">📍</span>
          <span class="link-content">
            <span class="link-label">Natsumi Buffet</span>
            <span class="link-sub">Open in Google Maps</span>
          </span>
        </a>

        <a class="link-item" href="tel:8586950888">
          <span class="link-icon">📞</span>
          <span class="link-content">
            <span class="link-label">Call Natsumi Buffet</span>
            <span class="link-sub">858.695.0888</span>
          </span>
        </a>
      </div>

      <div class="rsvp-note">
        Please RSVP by May 19th so we can plan accordingly.
      </div>
    </div>

    <footer>
      This page is intended for invited guests only.
    </footer>
  </div>
</body>
</html>
