---
import ProjectCard from "./ProjectCard.astro"
import { dataProjects} from "../data/projects.js"

const featuredProjects = [
  dataProjects[0], // Early Warning System
  dataProjects[2], // Washington Traffic Pipeline
  dataProjects[1], // Workplace Health Policy Optimization
  dataProjects[3] // School Sentiment NLP
  ]

  ---
<section id="projects" class="projects">
  <div class="container">
    <h2>Selected Projects</h2>

    <div class="project-grid">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.title}
          description={project.description}
          tools={project.tools}
          href={project.href}
        />
      ))}
    </div>
    <div class="projects-footer">
      <a class="all-projects" href="/projects">View all projects →</a> 
    </div>
  </div>
</section>

<style>
/* Projects section wrapper */
.projects {
  padding: 6rem 0;
  background: linear-gradient(135deg, #0f172a 0%, #020617 100%);
  color: #e5e7eb;
}

/* Align with hero width */
.container {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 2rem;
}

.projects h2 {
  font-size: 1.25rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #94a3b8;
  margin-bottom: 2rem;
}

/* Grid */
.project-grid {
  display: grid;
  gap: 1.5rem;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
}

.projects-footer {
  margin-top: 1.25rem;
}

.all-projects {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: #c7d2fe;
  text-decoration: none;
  font-weight: 600;
}

.all-projects:hover {
  text-decoration: underline;
}


</style>